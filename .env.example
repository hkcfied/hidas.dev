# Environment Variables
# Copy this file to .env and fill in values as needed

# This project is frontend-only and doesn't require any environment variables.
# If you plan to add backend integrations, add variables below:

# Example: Google Analytics
# VITE_GOOGLE_ANALYTICS_ID=

# Example: Sentry Error Tracking
# VITE_SENTRY_DSN=

# Example: Custom API Endpoint
# VITE_API_URL=https://api.example.com

# Note: Variables must be prefixed with VITE_ to be exposed to the browser
